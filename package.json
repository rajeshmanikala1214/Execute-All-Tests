{
  "name": "execute-test-cases",
  "version": "1.0.0",
  "scripts": {
    "start": "ui5 serve --port 8080",
    "test:opa": "ui5-test-runner --url http://localhost:8080/test/testsuite.qunit.html --start \"ui5 serve --port 8080\" --browser \"puppeteer --remote-debugging-address=localhost --remote-debugging-port=4444\"",
    "wdi5": "wdio run wdio.conf.js",
    "test:uiveri5": "uiveri5",
    "test": "npm run test:opa"
  },
  "devDependencies": {
    "@ui5/cli": "^4",
    "@ui5/uiveri5": "^1",
    "@wdio/cli": "^8",
    "@wdio/local-runner": "^8",
    "@wdio/mocha-framework": "^8",
    "@wdio/spec-reporter": "^8",
    "puppeteer": "^24",
    "ui5-middleware-simpleproxy": "^3.7.0",
    "ui5-test-runner": "^5",
    "wdio-ui5-service": "^2"
  }
}
