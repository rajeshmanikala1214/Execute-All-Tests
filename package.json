{
  "name": "execute-test-cases",
  "version": "1.0.0",
  "scripts": {
    "start": "ui5 serve --port 8080",
    "build": "ui5 build",
    "test:opa": "ui5-test-runner --url http://localhost:8080/test/testsuite.qunit.html --browser \"webdriver --url http://selenium:4444/wd/hub --browserName chrome\"",
    "test:opa:ci": "ui5 serve --port 8080 & sleep 20 && ui5-test-runner --url http://node:8080/test/testsuite.qunit.html --browser \"webdriver --url http://selenium:4444/wd/hub --browserName chrome\"",
    "wdi5": "wdio run wdio.conf.js",
    "wdi5:ci": "ui5 serve --port 8080 & sleep 20 && wdio run wdio.conf.js",
    "test:uiveri5": "uiveri5",
    "test": "npm run test:opa"
  },
  "devDependencies": {
    "@ui5/cli": "^4",
    "@ui5/uiveri5": "^1",
    "@wdio/cli": "^8",
    "@wdio/local-runner": "^8",
    "@wdio/mocha-framework": "^8",
    "@wdio/spec-reporter": "^8",
    "puppeteer": "^24",
    "ui5-middleware-simpleproxy": "^3.7.0",
    "ui5-test-runner": "^5",
    "wdio-ui5-service": "^2",
    "@wdio/junit-reporter": "^8"
  }
}