{
  "_version": "1.58.0",
  "sap.app": {
    "id": "execute.test.cases",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "Execute All Tests",
    "description": "App for running OPA5 and WDI5 tests",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "rootView": {
      "viewName": "execute.test.cases.view.Main",
      "type": "XML",
      "async": true,
      "id": "main"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    }
  }
}