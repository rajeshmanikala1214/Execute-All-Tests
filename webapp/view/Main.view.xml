<mvc:View
  controllerName="app.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m">

  <VBox>
    <List id="itemList" items="{path:'/items'}">
      <StandardListItem title="{name}" type="Active" press="onAddToCart" />
    </List>

    <Button text="Submit" press="onSubmit" id="submitBtn" />
  </VBox>

</mvc:View>